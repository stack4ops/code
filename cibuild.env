# LOG
CIBUILD_LOG_LEVEL=3

# TARGET
CIBUILD_TARGET_REGISTRY=docker.io
CIBUILD_TARGET_REGISTRY_USER=stack4ops
CIBUILD_TARGET_IMAGE_PATH=stack4ops/as-generic-code
CIBUILD_TARGET_TAG=latest

# CHECK
CIBUILD_CHECK_ENABLED=0

# BUILD
CIBUILD_BUILD_ENABLED=0
CIBUILD_BUILD_FORCE=1
CIBUILD_BUILD_NATIVE=1

# TEST
CIBUILD_TEST_ENABLED=1
CIBUILD_TEST_BACKEND=docker
CIBUILD_TEST_RUN_TIMEOUT=120
DOCKER_HOST=tcp://docker:2375

# DEPLOY
CIBUILD_ENABLED=0
CIBUILD_DEPLOY_MINOR_TAG_REGEX='^(1\.1\d\d)\.\d+$'
